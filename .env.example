# Myanmar LNP Dataset Configuration
# Copy this file to .env and fill in your values

# Hugging Face API Token (for downloading datasets)
HF_TOKEN=

# Weights & Biases API Key
WANDB_API_KEY=

# Groq API Key (for back-translation augmentation)
OPENAI_API_KEY=

# Database (optional)
NEON_DATABASE_URL=

# Model configuration
MODEL_NAME=bert-base-multilingual-cased
DEVICE=cuda